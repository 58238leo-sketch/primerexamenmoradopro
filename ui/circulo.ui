  <property name="styleSheet">
   <string notr="true">/* DISEÑO GENERAL DE LA VENTANA */
QDialog, QMainWindow {
    background-color: #1e222b; /* Fondo oscuro elegante */
    color: #ffffff;            /* Texto blanco */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
}

/* DISEÑO DE LOS CUADROS DE TEXTO (Inputs) */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #282c34;
    color: #ffffff;
    border: 2px solid #3f4451;
    border-radius: 6px;
    padding: 4px 8px; /* 👈 Baja estos números (por ejemplo a 4px y 8px) para darle más aire al texto */
}


/* Cuando el usuario hace clic para escribir en el cuadro de texto */
QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 2px solid #4b90ff; /* El borde cambia a azul brillante */
    background-color: #2c313c;
}

/* DISEÑO DE LAS ETIQUETAS DE TEXTO (Labels) */
QLabel {
    color: #abb2bf; /* Color gris claro/plateado para que no canse la vista */
    font-weight: 500;
}

/* DISEÑO DEL BOTÓN CALCULAR */
QPushButton {
    background-gradient: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #4b90ff, stop:1 #2766cc);
    background-color: #4b90ff; /* Azul base */
    color: #ffffff;
    font-weight: bold;
    border: none;
    border-radius: 6px;        /* Botón redondeado */
    padding: 10px 20px;
    min-height: 20px;
}

/* Cuando el usuario pasa el mouse sobre el botón */
QPushButton:hover {
    background-color: #619eff; /* Se vuelve un azul más vivo */
    cursor: pointer;
}

/* Cuando el usuario presiona el botón */
QPushButton:pressed {
    background-color: #1f54a8; /* Se oscurece un poco al hundirse */
    padding-top: 11px;         /* Efecto visual de click */
    padding-bottom: 9px;
}</string>
